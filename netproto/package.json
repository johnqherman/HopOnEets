{
  "name": "hop-on-eets-netproto",
  "version": "0.2.0",
  "private": true,
  "description": "Real-time relay server + mod bridge for Hop On Eets. No runtime deps; WebSocket over TCP (TypeScript).",
  "scripts": {
    "relay": "tsx relay.ts",
    "bridge": "tsx bridge.ts",
    "test": "ELO_FILE=/dev/null tsx e2e.ts",
    "test:e2e": "tsx e2e.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
